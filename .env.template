# ─── SLP Portal — Environment Variables Template ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── JWT Secret (REQUIRED in production) ──────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Admin credentials (REQUIRED — used for initial seed only) ────────────────
ADMIN_EMAIL=admin@slpsystems.ca
ADMIN_PASSWORD=change-me-strong-password   # Min 8 chars, uppercase + digit + special

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the .NET backend
NEXT_PUBLIC_API_URL=http://localhost:5062
# In production (when behind nginx): NEXT_PUBLIC_API_URL=https://yourdomain.com

# Public site URL (used for Open Graph / SEO meta tags)
NEXT_PUBLIC_SITE_URL=https://slpsystems.ca

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── SMTP (email sending) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=100     # requests per minute per IP

# ── GitHub Actions required secrets ──────────────────────────────────────────
# Set these in GitHub → Settings → Secrets and Variables → Actions:
#
# DEPLOY_HOST          = your server IP or hostname
# DEPLOY_USER          = SSH username (e.g. ubuntu)
# DEPLOY_SSH_KEY       = private SSH key (contents of ~/.ssh/id_rsa)
# DEPLOY_PORT          = SSH port (default 22)
# NEXT_PUBLIC_API_URL  = public API URL for production build
# JWT_SECRET           = JWT signing secret (same as above)
