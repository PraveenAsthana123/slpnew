{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=slpsystems.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "localhost,api.slpsystems.ca,slpsystems.ca",
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/slpsystems-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "https://revisions-over-isle-quotes.trycloudflare.com"
    ]
  },
  "RateLimit": {
    "MaxRequests": 100,
    "WindowSeconds": 60
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "SLPSystems",
    "Audience": "SLPSystemsApp",
    "ExpirationMinutes": 480
  },
  "Admin": {
    "Email": "",
    "Password": ""
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@slpsystems.ca",
    "FromName": "SLP Systems"
  }
}
